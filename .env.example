# Copy to .env and fill in. Never commit the real .env.

# Database
POSTGRES_USER=student_ai
POSTGRES_PASSWORD=change_me
POSTGRES_DB=student_ai_tool
DATABASE_URL=postgresql://student_ai:change_me@db:5432/student_ai_tool

# Auth
JWT_SECRET=change_me
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# LLM — Anthropic Claude (see docs/architecture.md — P0-SHR1)
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_FAST_MODEL=claude-haiku-3

# Embeddings — OpenAI text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Vector Store — Qdrant (self-hosted)
VECTOR_STORE_URL=http://vector-store:6333

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
